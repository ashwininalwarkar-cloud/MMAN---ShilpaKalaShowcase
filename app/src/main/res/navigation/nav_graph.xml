<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.shilpakalashowcase.ui.auth.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.shilpakalashowcase.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.shilpakalashowcase.ui.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.shilpakalashowcase.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboard_to_gallery"
            app:destination="@id/galleryFragment" />
        <action
            android:id="@+id/action_dashboard_to_heritage"
            app:destination="@id/heritageFragment" />
        <action
            android:id="@+id/action_dashboard_to_artistProfile"
            app:destination="@id/artistProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/galleryFragment"
        android:name="com.example.shilpakalashowcase.ui.gallery.GalleryFragment"
        android:label="Gallery"
        tools:layout="@layout/fragment_gallery">
        <action
            android:id="@+id/action_gallery_to_artworkDetail"
            app:destination="@id/artworkDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/artworkDetailFragment"
        android:name="com.example.shilpakalashowcase.ui.gallery.ArtworkDetailFragment"
        android:label="Artwork Detail"
        tools:layout="@layout/fragment_artwork_detail">
        <argument
            android:name="artworkId"
            app:argType="long" />
        <action
            android:id="@+id/action_artworkDetail_to_timeline"
            app:destination="@id/timelineFragment" />
    </fragment>

    <fragment
        android:id="@+id/artistProfileFragment"
        android:name="com.example.shilpakalashowcase.ui.profile.ArtistProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_artist_profile">
        <action
            android:id="@+id/action_profile_to_addArtwork"
            app:destination="@id/addArtworkFragment" />
        <action
            android:id="@+id/action_profile_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/addArtworkFragment"
        android:name="com.example.shilpakalashowcase.ui.profile.AddArtworkFragment"
        android:label="Add Artwork"
        tools:layout="@layout/fragment_add_artwork" />

    <fragment
        android:id="@+id/timelineFragment"
        android:name="com.example.shilpakalashowcase.ui.gallery.TimelineFragment"
        android:label="Timeline"
        tools:layout="@layout/fragment_timeline">
        <argument
            android:name="artworkId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/heritageFragment"
        android:name="com.example.shilpakalashowcase.ui.heritage.HeritageFragment"
        android:label="Heritage"
        tools:layout="@layout/fragment_heritage" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.shilpakalashowcase.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
